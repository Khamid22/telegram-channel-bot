# Core
APP_ENV=development
SECRET_KEY=change-me
TIMEZONE=Asia/Tashkent
DATABASE_URL=postgresql+psycopg2://vocab_bot:your_password@127.0.0.1:5432/vocabulary_bot

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@your_channel
TELEGRAM_PARSE_MODE=HTML

# OpenAI TTS
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE_UK=alloy

# Google Drive
GOOGLE_SERVICE_ACCOUNT_FILE=credentials.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_ROOT_FOLDER_NAME=writing-telegram-channel
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Admin
ADMIN_HOST=0.0.0.0
ADMIN_PORT=5050
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-now
START_SCHEDULER_WITH_ADMIN=true

# Storage
ASSETS_DIR=assets
TEMPLATE_CONFIG_DIR=assets/templates
GENERATED_IMAGE_DIR=assets/generated
GENERATED_AUDIO_DIR=assets/audio
